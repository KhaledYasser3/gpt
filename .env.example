PROJECT_NAME="AI Chat SaaS Platform"
API_V1_STR="/api/v1"

# PostgreSQL Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass_123
POSTGRES_DB=aichatsaas

# Database URLs
# For running inside docker-compose: postgresql+asyncpg://postgres:postgres_secure_pass_123@db:5432/aichatsaas
# For running locally (outside docker) pointing to mapped port: postgresql+asyncpg://postgres:postgres_secure_pass_123@localhost:5432/aichatsaas
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass_123@localhost:5432/aichatsaas
